# Хост и порт HTTP-сервера (uvicorn)
APP_HOST=0.0.0.0
APP_PORT=8000

# Уровень логирования в консоль: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Секрет для подписи JWT (в реальной среде — длинная случайная строка)
JWT_SECRET=замените-на-случайную-строку-не-коммитьте-реальный-секрет

# Срок действия токена в часах (по заданию Netology часть 2 — 48)
ACCESS_TOKEN_EXPIRE_HOURS=48

# Опционально: при первом запуске создать администратора (логин и пароль)
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=смените-пароль
